; =============================================================================
; sf_stream.inc — Mode-1 normal-BG level-streaming front door (Sprint S1).
; =============================================================================
; Clean-room kit macro surface over engine/bg_stream.asm (the horizontal BG1
; column-streaming PRODUCER) + the STREAM_PENDING drain in engine/nmi_handler.asm
; (the VBlank DMA CONSUMER). Lets a Mode-1 side-view game scroll a level WIDER
; than the 64-column BG1 hardware tilemap: columns ahead of the camera's
; leading edge stream into the VRAM ring window seamlessly as the camera moves,
; with no pop-in / tearing / black bands — forward, backward (reverse), and idle.
;
; HORIZONTAL ONLY in S1. The vertical (row) axis + 16-bit Y physics widening is
; S2; this macro is NAMED (sf_stream_*) so S2 extends it with sf_stream_set_cam's
; Y argument + an sf_stream_tick that services both axes, without a rename.
;
; --- Build wiring (the including ROM MUST do all of) ------------------------
;   1. BG1SC = $59 (64x32 BG1 tilemap @ VRAM word $5800-$5FFF) before init.
;   2. Link with a config giving the wide flat level its own bank(s)
;      (infrastructure/rom_template/lorom_stream.cfg, "; LDCFG: lorom_stream.cfg")
;      OR any config with a spare bank for the column-major level_flat.bin.
;   3. .include engine/bg_stream.asm (producer) AND engine/nmi_handler.asm —
;      the kit NMI handler already carries the STREAM_PENDING drain; NO extra
;      -D is needed (unlike the Mode 7 rail's MODE7_STREAM_NMI).
;   4. .include engine/hdma_alloc.asm BEFORE bg_stream.asm (provides
;      hdma_request; bg_stream allocates one DMA channel at init).
;   5. Provide the level constants (bg_stream_world.inc: BGW_WORLD_W_TILES,
;      BGW_COL_BYTES, ...) and the level_flat.bin column-major tilemap, both
;      generated by tools/level_pipeline_bg.py.
;
; --- UNITS CONTRACT (the load-bearing correctness point) --------------------
; The level is authored as 8x8-PX TILE columns and the producer's look-ahead
; counts TILE columns, so the caller MUST set the streaming cam in TILE-column
; units: STREAM_CAM_COL = cam_x >> 3 (NOT >> 4). sf_stream_set_cam does the
; >>3 for you. (The parent's /16 vs /8 mismatch was issue #125 — see
; engine/bg_stream.asm STREAM_LOOK_AHEAD comment.) The BG1 HOFS scroll
; register is set to cam_x by the game's NMI/scroll path as usual.
;
; --- Typical boot + loop shape ----------------------------------------------
;   ; under coldstart forced blank, after BG1SC=$59 + CHR/palette upload:
;   sf_stream_init level_flat, #BGW_WORLD_W_TILES   ; boot bulk-DMA cols 0..63
;   ; per frame, after advancing the camera (cam_x = world pixel X, 16-bit):
;   sf_stream_set_cam cam_x                          ; STREAM_CAM_COL = cam_x>>3
;   sf_stream_tick                                   ; queue leading/trailing cols
;   ; ...then commit BG1HOFS = cam_x and sf_frame_begin (NMI drains the queue).
; =============================================================================

.ifndef SF_STREAM_INC
SF_STREAM_INC = 1

; -----------------------------------------------------------------------------
; sf_stream_init level_ptr, width_tiles — boot streaming for a wide level.
; -----------------------------------------------------------------------------
;   level_ptr     a LABEL of the column-major flat level data (the macro takes
;                 .loword/^ of it to build the 24-bit ROM pointer).
;   width_tiles   level width in 8x8 TILE columns (e.g. #BGW_WORLD_W_TILES),
;                 a 16-bit immediate or absolute operand.
; Fills the producer's DP $20-$24 API block (24-bit ptr + 16-bit width) and
; JSRs bg_stream_init, which bulk-DMAs the first 64 columns into BG1 VRAM.
; Call ONCE during boot, under forced blank (the boot DMA halts the CPU).
; Clobbers A, X, Y. Asserts A8 entry/exit (matches the producer's working
; width); establishes I16 internally.
;
; DX (S2b-M2): the BG_TILEMAP_DIRTY DISOWN is now BAKED IN here. The kit NMI
; handler DMAs SHADOW_BG1_TILEMAP over VRAM $5800 whenever BG_TILEMAP_DIRTY
; bit 0 is set (gfxmode / sf_level_init leave it dirty) — that would WIPE the
; streamed columns every frame, a black-screen trap every streaming ROM used
; to hit. In streaming mode the ring + the STREAM_PENDING/STREAM_ROW_PENDING
; consumers OWN the BG1 tilemap VRAM, so the streaming front door clears the
; dirty mask at init. (Was a per-ROM manual `stz BG_TILEMAP_DIRTY` step —
; bg_stream_test.asm / bg_stream2d_test.asm carried it inline; this macro now
; owns it so no streaming ROM can forget it.) Streaming ROMs must never set
; BG1 dirty again after this point.
; WIDTH-RISK: fills the $20-$24 block in A16, then sep #$20 (.a8) before the
; JSR to match bg_stream_init's A8 entry contract; the routine exits A8/I16.
.macro sf_stream_init sf_level_ptr, sf_width
    rep #$20
    .a16
    lda #.loword(sf_level_ptr)
    sta $20                     ; level ptr low 16
    sep #$20
    .a8
    lda #^sf_level_ptr
    sta $22                     ; level ptr bank
    rep #$20
    .a16
    lda sf_width
    sta $23                     ; level width in tile columns (16-bit)
    sep #$20
    .a8
    jsr bg_stream_init
    ; --- DX: disown BG1 tilemap from the engine's full-tilemap DMA (S2b-M2).
    ; Clear ALL layer dirty bits so the engine never re-DMAs SHADOW_BG1_TILEMAP
    ; over the streamed ring. A8 here (post-JSR width contract); BG_TILEMAP_DIRTY
    ; is a 1-byte DP-relative flag at $013C.
    lda #$00
    sta BG_TILEMAP_DIRTY        ; ; ZP-LINT: ok — BG_TILEMAP_DIRTY is a declared ES_* symbol (engine_state.inc)
.endmacro

; -----------------------------------------------------------------------------
; sf_stream_set_cam cam_x — update the streaming camera column from world X.
; -----------------------------------------------------------------------------
;   cam_x   world camera PIXEL X (16-bit integer), verbatim operand. The macro
;           computes STREAM_CAM_COL = cam_x >> 3 (8px tile columns) — the unit
;           the producer's look-ahead counts. Call BEFORE sf_stream_tick each
;           frame. This is the SAME cam_x you commit to BG1HOFS.
; Clobbers A. Asserts A16/I16 in, exits A8/I16 (the producer's working width).
; WIDTH-RISK: does the >>3 in A16, stores the byte result in A8.
.macro sf_stream_set_cam sf_cam_x
    rep #$30
    .a16
    .i16
    lda sf_cam_x
    lsr
    lsr
    lsr                         ; cam_x >> 3 = tile column index
    sta f:$7E0000 + STREAM_CAM_COL
    sep #$20
    .a8
.endmacro

; -----------------------------------------------------------------------------
; sf_stream_tick — per-frame main-thread streaming service. Queues any newly
; entered leading (forward) / trailing (reverse) columns into the
; STREAM_PENDING slot table; the NMI consumer DMAs them into BG1 VRAM next
; VBlank. Cheap when the camera is idle (a compare + early-out).
; -----------------------------------------------------------------------------
; Call AFTER sf_stream_set_cam and BEFORE the next sf_frame_begin (so that
; frame's NMI drains the freshly-queued columns). Clobbers A, X, Y and the
; streaming DP scratch. Asserts A8 entry/exit (the producer's working width).
; WIDTH-RISK: sep #$20 to A8 before the JSR; bg_stream_tick manages its own
; A8/A16 spans internally and exits A8/I16.
.macro sf_stream_tick
    rep #$10
    .i16
    sep #$20
    .a8
    jsr bg_stream_tick
.endmacro

; =============================================================================
; --- S2a: VERTICAL (row) axis extension ------------------------------------
; =============================================================================
; The 2-axis substrate adds a row producer (engine/bg_stream_row.asm) alongside
; the column producer. A 2-axis ROM:
;   1. sets BG1SC = $5B (64x64 tilemap @ VRAM word $5800) before init,
;   2. .includes engine/bg_stream_row.asm (after engine/bg_stream.asm),
;   3. calls BOTH sf_stream_init (horizontal, column-major level) AND
;      sf_stream_row_init (vertical, row-major level) at boot under forced blank,
;   4. each frame calls sf_stream_set_cam2 (both axes) then sf_stream_tick2.
; The row producer reuses the column producer's allocated DMA channel.

; -----------------------------------------------------------------------------
; sf_stream_row_init level_row_ptr, height_tiles — boot vertical streaming.
; -----------------------------------------------------------------------------
;   level_row_ptr   LABEL of the ROW-MAJOR flat level data.
;   height_tiles    level height in 8x8 TILE rows (e.g. #BGW_WORLD_H_TILES).
; Fills the row producer's DP $25-$29 API block and JSRs bg_stream_row_init,
; which stages + bulk-DMAs the first 64 rows into the BG1 64x64 ring. Call ONCE
; at boot under forced blank, AFTER sf_stream_init. Clobbers A, X, Y. A8 in/out.
; WIDTH-RISK: fills $25-$29 in A16, sep #$20 before the JSR (A8 entry contract).
.macro sf_stream_row_init sf_row_ptr, sf_height
    rep #$20
    .a16
    lda #.loword(sf_row_ptr)
    sta $25                     ; row-major level ptr low 16
    sep #$20
    .a8
    lda #^sf_row_ptr
    sta $27                     ; row-major level ptr bank
    rep #$20
    .a16
    lda sf_height
    sta $28                     ; level height in tile rows (16-bit)
    sep #$20
    .a8
    jsr bg_stream_row_init
.endmacro

; -----------------------------------------------------------------------------
; sf_stream_set_cam2 cam_x, cam_y — update BOTH streaming camera tile indices.
; -----------------------------------------------------------------------------
;   cam_x   world camera PIXEL X (16-bit). STREAM_CAM_COL = cam_x >> 3.
;   cam_y   world camera PIXEL Y (16-bit). STREAM_CAM_ROW = cam_y >> 3.
; Call BEFORE sf_stream_tick2 each frame. Clobbers A. A16/I16 in, A8/I16 out.
; WIDTH-RISK: both >>3 in A16, store byte results in A8.
.macro sf_stream_set_cam2 sf_cam_x, sf_cam_y
    rep #$30
    .a16
    .i16
    lda sf_cam_x
    lsr
    lsr
    lsr                         ; cam_x >> 3 = tile column
    sta f:$7E0000 + STREAM_CAM_COL
    lda sf_cam_y
    lsr
    lsr
    lsr                         ; cam_y >> 3 = tile row
    sta f:$7E0000 + STREAM_CAM_ROW
    sep #$20
    .a8
.endmacro

; -----------------------------------------------------------------------------
; sf_stream_tick2 — per-frame 2-axis service: column tick THEN row tick.
; -----------------------------------------------------------------------------
; Columns first (the horizontal ring window the row stager reads), then rows.
; Call AFTER sf_stream_set_cam2 and BEFORE the next sf_frame_begin. Clobbers
; A, X, Y. A8 in/out.
; WIDTH-RISK: sep #$20 / rep #$10 before each JSR; the producers manage their
; own A8/A16 spans and exit A8/I16. Entry + exit are A8/I16.
.macro sf_stream_tick2
    rep #$10
    .i16
    sep #$20
    .a8
    jsr bg_stream_tick
    rep #$10
    .i16
    sep #$20
    .a8
    jsr bg_stream_row_tick
.endmacro

.endif ; SF_STREAM_INC
