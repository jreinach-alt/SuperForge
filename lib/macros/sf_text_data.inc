; =============================================================================
; sf_text_data.inc — text-engine data + routines (macro library, link partner)
; =============================================================================
; The emitted half of sf_text.inc: the built-in font, the decimal-conversion
; routine, and the engine's string-pool bank byte. Unlike the macro files,
; this file EMITS bytes — include it ONCE at the BOTTOM of main.asm, inside
; the CODE segment, next to the engine .asm includes:
;
;   .include "text_engine.asm"
;   .include "sf_text_data.inc"
;
; (If you forget it, the link fails naming sf_font_2bpp / _sf_u16_to_dec5 —
; that's your cue.)
; =============================================================================

.ifndef SF_TEXT_DATA_INC
SF_TEXT_DATA_INC = 1

; -----------------------------------------------------------------------------
; _string_pool_bank — the text engine's fallback string bank.
; -----------------------------------------------------------------------------
; engine_print reads the string's bank byte from the API block; when the
; caller passes bank 0 it falls back to this byte. Kit ROMs keep strings in
; bank $00 (32KB LoROM), so the fallback is $00. Without this byte the ROM
; does not link (the engine references it unconditionally).
.export _string_pool_bank
_string_pool_bank:
    .byte $00

; -----------------------------------------------------------------------------
; _sf_u16_to_dec5 — convert 16-bit A to 5 ASCII digits + NUL at SF_DEC_BUF.
; -----------------------------------------------------------------------------
; In:  A = value 0-65535 (16-bit). Requires DB=$00 (writes low WRAM absolute).
; Out: SF_DEC_BUF..+4 = zero-padded ASCII digits, SF_DEC_BUF+5 = NUL.
; Clobbers A, X, Y.
; WIDTH-RISK: asserts A16/I16 entry; toggles A8 for the byte stores; exits
; A16/I16. Every loop label below carries its runtime width explicitly.
_sf_u16_to_dec5:
    rep #$30
    .a16
    .i16
    ldx #$0000                  ; power-table byte offset: 0,2,4,6
@pow:
    .a16
    ldy #$0030                  ; ASCII '0'
@sub:
    .a16
    cmp f:_sf_dec_pows, x       ; value < power -> this digit is done
    bcc @emit
    sec
    sbc f:_sf_dec_pows, x
    iny                         ; count one subtraction = +1 digit
    bra @sub
@emit:
    .a16
    pha                         ; save the remaining value
    phx                         ; save the power offset
    txa
    lsr                         ; byte offset -> digit index 0..3
    tax
    tya                         ; A = ASCII digit ('0' + count, fits in 8 bits)
    sep #$20
    .a8
    sta a:SF_DEC_BUF, x         ; buf[digit]  (DB=$00 -> low WRAM)
    rep #$20
    .a16
    plx
    pla
    inx
    inx
    cpx #$0008                  ; 4 powers done?
    bcc @pow
    ; ones digit = the remaining value (0-9)
    clc
    adc #$0030                  ; '0' + value
    sep #$20
    .a8
    sta a:SF_DEC_BUF + 4
    lda #$00
    sta a:SF_DEC_BUF + 5        ; NUL terminator
    rep #$20
    .a16
    rts

_sf_dec_pows:
    .word 10000, 1000, 100, 10

